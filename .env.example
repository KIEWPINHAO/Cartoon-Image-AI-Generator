# VITE_GEMINI_API_KEY: Required for Gemini AI API calls
# Get your API key from: https://ai.google.dev/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# VITE_APP_URL: The URL where this app is hosted
# For local development, use http://localhost:5173
# For Vercel, this will be your deployed URL (e.g., https://your-app.vercel.app)
VITE_APP_URL=http://localhost:5173
